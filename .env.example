# Database
DATABASE_URL="postgresql://user:password@localhost:5432/arabgram?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/arabgram?schema=public"

# NextAuth
NEXTAUTH_SECRET="your-nextauth-secret-here-use-openssl-rand-hex-32"
NEXTAUTH_URL="http://localhost:3000"

# JWT Secret (for token generation)
JWT_SECRET="your-jwt-secret-here-use-openssl-rand-hex-32"

# Email Configuration (for verification codes)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_SECURE="false"
EMAIL_USER="your-email@gmail.com"
EMAIL_PASSWORD="your-app-password"
EMAIL_FROM="noreply@arabgram.com"

# Security
CSRF_SECRET="your-csrf-secret-here-use-openssl-rand-hex-32"

# API Configuration
API_RATE_LIMIT="100"
API_RATE_LIMIT_WINDOW_MS="900000"

# Auth Rate Limiting
AUTH_RATE_LIMIT="30"
AUTH_RATE_LIMIT_WINDOW_MS="900000"

# Session Configuration
SESSION_EXPIRY="86400000"
REFRESH_TOKEN_EXPIRY="604800000"

# Security Headers
ENABLE_HSTS="true"
ENABLE_CSP="true"
ENABLE_X_FRAME_OPTIONS="true"

# Logging
LOG_LEVEL="info"
LOG_FILE="./logs/app.log"

# Feature Flags
ENABLE_EMAIL_VERIFICATION="true"
ENABLE_TWO_FACTOR_AUTH="false"
ENABLE_SOCIAL_LOGIN="false"

# External Services
REDIS_URL="redis://localhost:6379"
S3_BUCKET="arabgram-uploads"
S3_REGION="us-east-1"
S3_ACCESS_KEY="your-s3-access-key"
S3_SECRET_KEY="your-s3-secret-key"

# Analytics
ANALYTICS_ENABLED="true"
ANALYTICS_ID="your-analytics-id"

# Environment
NODE_ENV="development"
