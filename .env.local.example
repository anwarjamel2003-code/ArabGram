# ============================================
# ArabGram Environment Variables for Vercel
# ============================================

# Database Configuration
# Use Neon, Supabase, or any PostgreSQL provider
DATABASE_URL="postgresql://user:password@host:5432/arabgram?sslmode=require"

# NextAuth Configuration
# Generate using: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="https://your-domain.com"

# JWT Configuration
# Generate using: openssl rand -base64 32
JWT_SECRET="your-jwt-secret-here"

# Email Configuration (for verification codes)
# Gmail example:
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_SECURE="false"
EMAIL_USER="your-email@gmail.com"
EMAIL_PASSWORD="your-app-password"
EMAIL_FROM="noreply@arabgram.com"

# Alternative Email Providers:
# SendGrid: smtp.sendgrid.net:587
# Mailgun: smtp.mailgun.org:587
# AWS SES: email-smtp.region.amazonaws.com:587

# Security Configuration
CSRF_SECRET="your-csrf-secret-here"

# Supabase Realtime (WebRTC Signaling & Chat)
# Get these from your Supabase Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Web Push Notifications (VAPID)
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY="BLPCq34oPaFEH7cHqJW3obW2hIUq7ZaaTaLy7dl_89h3mfpsCb6H2PxfPxS4fOyDSwowA7UyWEFeKGnWtUT6US0"
VAPID_PRIVATE_KEY="tYz9PO9aJ1ZGoz5YJbk4MbeTJlokL0W7KySjLibgprc"
VAPID_SUBJECT="mailto:support@arabgram.com"

# Rate Limiting
API_RATE_LIMIT="100"
API_RATE_LIMIT_WINDOW_MS="900000"
AUTH_RATE_LIMIT="30"
AUTH_RATE_LIMIT_WINDOW_MS="900000"

# Session Configuration
SESSION_EXPIRY="86400000"
REFRESH_TOKEN_EXPIRY="604800000"

# Security Headers
ENABLE_HSTS="true"
ENABLE_CSP="true"
ENABLE_X_FRAME_OPTIONS="true"

# Logging
LOG_LEVEL="info"

# Feature Flags
ENABLE_EMAIL_VERIFICATION="true"
ENABLE_TWO_FACTOR_AUTH="false"
ENABLE_SOCIAL_LOGIN="false"

# Environment
NODE_ENV="production"

# Optional: Analytics
ANALYTICS_ENABLED="false"
ANALYTICS_ID=""

# Optional: S3 Configuration (for image uploads)
# S3_BUCKET="arabgram-uploads"
# S3_REGION="us-east-1"
# S3_ACCESS_KEY=""
# S3_SECRET_KEY=""

# Optional: Redis (for caching and sessions)
# REDIS_URL="redis://default:password@host:6379"
