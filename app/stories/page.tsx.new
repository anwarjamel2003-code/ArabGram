                <div className=\"relative z-10\">
                  <p className=\"font-semibold text-sm line-clamp-2\">{story.user}</p>
                  <div className=\"flex items-center space-x-1 text-xs opacity-90 mt-1\">
                    <Clock className=\"h-3 w-3\" />
                    <span>{story.expires}</span>
                  </div>
                </div>
              </CardContent>
            </Card>
          </Link>
        ))}
